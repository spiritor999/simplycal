# 简便运算智能体 - 环境变量配置

# ========================================
# Coze 平台配置（必需）
# ========================================

# API 密钥（从 Coze 平台获取）
COZE_WORKLOAD_IDENTITY_API_KEY=your_api_key_here

# 模型服务地址
COZE_INTEGRATION_MODEL_BASE_URL=https://api.coze.com

# ========================================
# 服务配置（可选，通常不需要修改）
# ========================================

# 服务端口（默认 8000）
PORT=8000

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 工作目录（默认 /app）
COZE_WORKSPACE_PATH=/app

# ========================================
# 高级配置（通常不需要修改）
# ========================================

# 超时时间（秒）
TIMEOUT=600

# 最大消息数
MAX_MESSAGES=60

# 是否启用缓存
ENABLE_CACHE=true
