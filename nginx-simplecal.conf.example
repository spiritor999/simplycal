# 简便运算智能体 - Nginx 配置示例
# 用于配置 HTTPS 访问
# 注意：这是独立配置，与现有 materials 项目的 Nginx 配置分开

# 方法1: 添加到现有 Nginx 配置（推荐）
# 将以下配置添加到你的 nginx/nginx.conf 文件中

server {
    listen 80;
    server_name simplecal.yourdomain.com;  # 替换为你的域名

    # 重定向到 HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name simplecal.yourdomain.com;  # 替换为你的域名

    # SSL 证书（使用现有的证书或申请新的）
    ssl_certificate /etc/nginx/ssl/simplecal.crt;
    ssl_certificate_key /etc/nginx/ssl/simplecal.key;

    # SSL 配置
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # 日志
    access_log /var/log/nginx/simplecal_access.log;
    error_log /var/log/nginx/simplecal_error.log;

    # 代理到智能体服务
    location / {
        proxy_pass http://simplecal_agent:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket 支持
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # 超时设置
        proxy_connect_timeout 600s;
        proxy_send_timeout 600s;
        proxy_read_timeout 600s;
    }

    # 静态文件（游戏页面）
    location /games/ {
        alias /var/www/simplecal/games/;
        index index.html;
    }
}

